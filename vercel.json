{
  "version": 2,
  "name": "instalight-flow",
  "rewrites": [
    { "source": "/", "destination": "/gd-docs-instalight.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
